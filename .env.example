# Configuração do serviço de cálculo de combustível
# Copie para .env e ajuste conforme o ambiente

APP_NAME=fuel-consumption-api
VERSION=0.1.0
ENVIRONMENT=dev
LOG_LEVEL=INFO

# CORS - use lista separada por vírgulas. Ex.: "https://app.example.com,https://admin.example.com"
# Use "*" apenas em desenvolvimento.
CORS_ORIGINS=*

# Limite de requisições no endpoint /calculate/batch
BATCH_SIZE_LIMIT=100

# Tamanho do segmento de integração (metros) usado na simulação da viagem
SEGMENT_LENGTH_M=100
